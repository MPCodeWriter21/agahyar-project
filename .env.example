# Django secret key -- generate a strong key for production
SECRET_KEY=change-me-to-a-random-secret-key

# Set to False in production
DEBUG=True

# Public-facing site URL (used for sitemap.xml, robots.txt, canonical URLs)
SITE_URL=https://agahyar.ir

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# Change the admin panel URL in production (e.g. "secret-admin/")
ADMIN_URL=admin/

# Security settings -- enable these in production
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Database configuration (defaults to SQLite)
# For PostgreSQL, set these:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=agahyar
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=db
# DB_PORT=5432
# Leave DB_NAME empty (or unset) to use the default SQLite path (db.sqlite3)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=

# Redis URL (used for caching and session storage in production)
# REDIS_URL=redis://redis:6379/1
