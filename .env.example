# Django secret key -- generate a strong key for production
SECRET_KEY=change-me-to-a-random-secret-key

# Set to False in production
DEBUG=True

# Domain used by Traefik for routing (e.g. "agahyar4iran.ir")
DOMAIN=agahyar.localhost

# Optional overrides (defaults are derived from DOMAIN):
# ALLOWED_HOSTS=localhost,127.0.0.1,agahyar4iran.ir,www.agahyar4iran.ir
# SITE_URL=https://agahyar4iran.ir
# CSRF_TRUSTED_ORIGINS=https://agahyar4iran.ir,https://www.agahyar4iran.ir,http://agahyar4iran.ir,http://www.agahyar4iran.ir

# Change the admin panel URL in production (e.g. "secret-admin/")
ADMIN_URL=admin/

# Security settings -- enable these in production
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Database configuration
# Docker (dev & prod) uses PostgreSQL -- uncomment these:
DB_ENGINE=django.contrib.gis.db.backends.postgis
DB_NAME=agahyar
DB_USER=agahyar
DB_PASSWORD=agahyar_dev
DB_HOST=db
DB_PORT=5432

# Redis URL (used for caching and session storage)
# Comment if not using docker
REDIS_URL=redis://redis:6379/1

# SMS.ir configuration (for OTP phone verification)
SMS_IR_API_KEY=your-sms-api-key
SMS_IR_OTP_TEMPLATE_ID=123456

# Set to True in development to skip sending actual SMS
DISABLE_SMS=True

# OTP settings
OTP_EXPIRE_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60

# Neshan Maps search API key (for admin map widget search)
# Get yours at https://platform.neshan.org/
# NESHAN_API_KEY=your-neshan-api-key

# Performance profiling -- enable to get per-request profiling reports
# ENABLE_PROFILING=True

# Sentry error tracking (disabled when empty)
# SENTRY_DSN=https://your-dsn@sentry.io/project-id
