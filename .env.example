# Django secret key -- generate a strong key for production
SECRET_KEY=change-me-to-a-random-secret-key

# Set to False in production
DEBUG=True

# Domain used by Traefik for routing (e.g. "agahyar.ir")
DOMAIN=agahyar.ir

# Optional overrides (defaults are derived from DOMAIN):
# ALLOWED_HOSTS=localhost,127.0.0.1,agahyar.ir,www.agahyar.ir
# SITE_URL=https://agahyar.ir
# CSRF_TRUSTED_ORIGINS=https://agahyar.ir,https://www.agahyar.ir,http://agahyar.ir,http://www.agahyar.ir

# Change the admin panel URL in production (e.g. "secret-admin/")
ADMIN_URL=admin/

# Security settings -- enable these in production
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Database configuration
# Docker (dev & prod) uses PostgreSQL -- uncomment these:
DB_ENGINE=django.contrib.gis.db.backends.postgis
DB_NAME=agahyar
DB_USER=agahyar
DB_PASSWORD=agahyar_dev
DB_HOST=db
DB_PORT=5432

# Redis URL (used for caching and session storage)
# Comment if not using docker
REDIS_URL=redis://redis:6379/1
